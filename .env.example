# Database
# If not using docker, set DATABASE_URL to hosted postgres url and ignore the other database variables.
DATABASE_URL="postgresql://tablecn:securepassword@localhost:5432/tablecn"

DATABASE_HOST="localhost"
DATABASE_USER="tablecn"
DATABASE_PASSWORD="securepassword"
DATABASE_NAME="tablecn"
DATABASE_PORT="5432"

# Storage (optional for data-grid-live)
UPLOADTHING_TOKEN="token"

# Rate limiter (optional for data-grid-live)
UPSTASH_REDIS_REST_URL="url"
UPSTASH_REDIS_REST_TOKEN="token"

# Multiplayer (optional for data-grid-multiplayer)
# Local dev: localhost:1999 (partykit dev server default)
# Production: <your-project>.partykit.dev
NEXT_PUBLIC_PARTYKIT_HOST="localhost:1999"
