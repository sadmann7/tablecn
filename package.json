{
  "name": "tablecn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf --glob **/node_modules **/dist **/.next pnpm-lock.yaml **/.tsbuildinfo",
    "build": "next build",
    "dev": "next dev",
    "dev:multiplayer": "concurrently \"next dev\" \"partykit dev\"",
    "deploy:multiplayer": "partykit deploy",
    "test": "vitest run",
    "dev:docker": "pnpm db:start && pnpm dev",
    "start": "next start",
    "ollie": "pnpm install && pnpm run db:start && pnpm run db:setup",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck",
    "shadcn": "pnpm dlx shadcn@latest",
    "build:registry": "shadcn build",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:generate": "dotenv drizzle-kit generate",
    "db:introspect": "dotenv drizzle-kit introspect",
    "db:push": "dotenv drizzle-kit push",
    "db:migrate": "dotenv tsx src/db/migrate.ts",
    "db:drop-migration": "drizzle-kit drop",
    "db:seed": "dotenv tsx src/db/seed.ts",
    "db:setup": "pnpm db:push && pnpm db:seed",
    "db:reset": "pnpm db:stop && rimraf docker-data && pnpm db:start && sleep 10 && pnpm db:setup",
    "db:studio": "dotenv drizzle-kit studio"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/query-db-collection": "^1.0.40",
    "@tanstack/react-db": "^0.1.86",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "@uploadthing/react": "^7.3.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "export-to-csv": "^1.4.0",
    "geist": "^1.7.2",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "partysocket": "^1.2.0",
    "postgres": "^3.4.9",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-day-picker": "^9.7.0",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "server-only": "^0.0.1",
    "shadcn": "4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "uploadthing": "^7.7.4",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@faker-js/faker": "^10.4.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "partykit": "^0.0.115",
    "postcss": "^8.5.15",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "ct3aMetadata": {
    "initVersion": "7.23.1"
  },
  "packageManager": "pnpm@10.26.1"
}
